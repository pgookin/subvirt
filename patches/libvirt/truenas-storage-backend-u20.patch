diff -ruN libvirt-u20-clean.orig/src/storage/storage_backend_truenas.c libvirt-u20-clean/src/storage/storage_backend_truenas.c
--- libvirt-u20-clean.orig/src/storage/storage_backend_truenas.c	1969-12-31 19:00:00.000000000 -0500
+++ libvirt-u20-clean/src/storage/storage_backend_truenas.c	2026-07-08 04:02:36.744680420 -0400
@@ -0,0 +1,585 @@
+/*
+ * storage_backend_truenas.c: storage backend for TrueNAS provider daemon
+ */
+
+#include <config.h>
+
+#include <errno.h>
+#include <sys/socket.h>
+#include <sys/un.h>
+#include <unistd.h>
+
+#include "storage_conf.h"
+#include "storage_backend.h"
+#include "storage_backend_truenas.h"
+#include "storage_util.h"
+#include "viralloc.h"
+#include "virerror.h"
+#include "virfile.h"
+#include "virjson.h"
+#include "virlog.h"
+#include "virstring.h"
+
+#define VIR_FROM_THIS VIR_FROM_STORAGE
+
+VIR_LOG_INIT("storage.storage_backend_truenas");
+
+#define TRUENAS_PROVIDER_SOCKET "/run/truenas-libvirt/provider.sock"
+
+static const char *
+virStorageBackendTrueNASTransport(virStoragePoolDefPtr def)
+{
+    if (def->source.protocolType)
+        return def->source.protocolType;
+
+    return def->source.product;
+}
+
+static int
+virStorageBackendTrueNASValidate(virStoragePoolDefPtr def)
+{
+    const char *transport = virStorageBackendTrueNASTransport(def);
+
+    if (!def->source.name) {
+        virReportError(VIR_ERR_CONFIG_UNSUPPORTED, "%s",
+                       _("TrueNAS storage pool requires source name"));
+        return -1;
+    }
+
+    if (!transport || !(STREQ(transport, "iscsi") || STREQ(transport, "nvmeof"))) {
+        virReportError(VIR_ERR_CONFIG_UNSUPPORTED, "%s",
+                       _("TrueNAS storage pool requires protocol type 'iscsi' or 'nvmeof'"));
+        return -1;
+    }
+
+    return 0;
+}
+
+static int
+virStorageBackendTrueNASConnect(void)
+{
+    struct sockaddr_un addr = { 0 };
+    int fd;
+
+    if ((fd = socket(AF_UNIX, SOCK_STREAM, 0)) < 0) {
+        virReportSystemError(errno, "%s", _("failed to create TrueNAS provider socket"));
+        return -1;
+    }
+
+    addr.sun_family = AF_UNIX;
+    if (virStrcpyStatic(addr.sun_path, TRUENAS_PROVIDER_SOCKET) < 0) {
+        virReportError(VIR_ERR_INTERNAL_ERROR, "%s", _("TrueNAS provider socket path is too long"));
+        VIR_FORCE_CLOSE(fd);
+        return -1;
+    }
+
+    if (connect(fd, (struct sockaddr *) &addr, sizeof(addr)) < 0) {
+        virReportSystemError(errno,
+                             _("TrueNAS provider daemon is not available at %s; install/configure the truenas-libvirt-provider package and start truenas-libvirt-provider.service"),
+                             TRUENAS_PROVIDER_SOCKET);
+        VIR_FORCE_CLOSE(fd);
+        return -1;
+    }
+
+    return fd;
+}
+
+static int
+virStorageBackendTrueNASWriteAll(int fd, const char *buf, size_t len)
+{
+    while (len > 0) {
+        ssize_t done = write(fd, buf, len);
+        if (done < 0) {
+            if (errno == EINTR)
+                continue;
+            return -1;
+        }
+        if (done == 0) {
+            errno = EIO;
+            return -1;
+        }
+        buf += done;
+        len -= done;
+    }
+    return 0;
+}
+
+static virJSONValuePtr
+virStorageBackendTrueNASCall(const char *method,
+                             virJSONValuePtr params)
+{
+    int fd = -1;
+    char *requeststr = NULL;
+    char *responsestr = NULL;
+    char *responsebuf = NULL;
+    virJSONValuePtr request = NULL;
+    virJSONValuePtr response = NULL;
+    virJSONValuePtr result = NULL;
+    virJSONValuePtr error = NULL;
+    size_t offset = 0;
+    int ret = -1;
+
+    if (VIR_ALLOC_N(responsebuf, 1024 * 1024 + 1) < 0)
+        goto cleanup;
+
+    if (!(request = virJSONValueNewObject()))
+        goto cleanup;
+
+    if (virJSONValueObjectAppendString(request, "jsonrpc", "2.0") < 0 ||
+        virJSONValueObjectAppendNumberInt(request, "id", 1) < 0 ||
+        virJSONValueObjectAppendString(request, "method", method) < 0 ||
+        virJSONValueObjectAppend(request, "params", params) < 0)
+        goto cleanup;
+    params = NULL;
+
+    if (!(requeststr = virJSONValueToString(request, false)))
+        goto cleanup;
+
+    if ((fd = virStorageBackendTrueNASConnect()) < 0)
+        goto cleanup;
+
+    if (virStorageBackendTrueNASWriteAll(fd, requeststr, strlen(requeststr)) < 0 ||
+        virStorageBackendTrueNASWriteAll(fd, "\n", 1) < 0) {
+        virReportSystemError(errno, "%s", _("failed to write TrueNAS provider request"));
+        goto cleanup;
+    }
+
+    for (;;) {
+        ssize_t nread;
+        if (offset >= 1024 * 1024) {
+            virReportError(VIR_ERR_INTERNAL_ERROR, "%s",
+                           _("TrueNAS provider response exceeded 1 MiB"));
+            goto cleanup;
+        }
+
+        nread = read(fd, responsebuf + offset, 1024 * 1024 - offset);
+        if (nread < 0) {
+            if (errno == EINTR)
+                continue;
+            virReportSystemError(errno, "%s", _("failed to read TrueNAS provider response"));
+            goto cleanup;
+        }
+        if (nread == 0)
+            break;
+        offset += nread;
+        responsebuf[offset] = '\0';
+        if (memchr(responsebuf, '\n', offset))
+            break;
+    }
+
+    if (offset == 0) {
+        virReportError(VIR_ERR_INTERNAL_ERROR, "%s",
+                       _("empty response from TrueNAS provider"));
+        goto cleanup;
+    }
+
+    responsestr = g_steal_pointer(&responsebuf);
+
+    if (!(response = virJSONValueFromString(responsestr))) {
+        virReportError(VIR_ERR_INTERNAL_ERROR, "%s", _("invalid JSON from TrueNAS provider"));
+        goto cleanup;
+    }
+
+    if ((error = virJSONValueObjectGetObject(response, "error"))) {
+        const char *message = virJSONValueObjectGetString(error, "message");
+        virReportError(VIR_ERR_INTERNAL_ERROR,
+                       _("TrueNAS provider error: %s"),
+                       message ? message : _("unknown error"));
+        goto cleanup;
+    }
+
+    if (virJSONValueObjectRemoveKey(response, "result", &result) <= 0) {
+        virReportError(VIR_ERR_INTERNAL_ERROR, "%s", _("missing result from TrueNAS provider"));
+        goto cleanup;
+    }
+
+    ret = 0;
+
+ cleanup:
+    VIR_FORCE_CLOSE(fd);
+    virJSONValueFree(params);
+    virJSONValueFree(request);
+    virJSONValueFree(response);
+    VIR_FREE(requeststr);
+    VIR_FREE(responsestr);
+    VIR_FREE(responsebuf);
+    if (ret < 0) {
+        virJSONValueFree(result);
+        result = NULL;
+    }
+    return result;
+}
+
+static int
+virStorageBackendTrueNASAppendCommonParams(virJSONValuePtr params,
+                                           virStoragePoolDefPtr def)
+{
+    const char *transport = virStorageBackendTrueNASTransport(def);
+
+    if (virJSONValueObjectAppendString(params, "pool", def->source.name) < 0 ||
+        virJSONValueObjectAppendString(params, "transport", transport) < 0)
+        return -1;
+    return 0;
+}
+
+static int
+virStorageBackendTrueNASAddVolume(virStoragePoolObjPtr pool,
+                                  virJSONValuePtr item)
+{
+    virStorageVolDefPtr vol = NULL;
+    const char *name = virJSONValueObjectGetString(item, "name");
+    const char *path = virJSONValueObjectGetString(item, "path");
+    unsigned long long capacity = 0;
+    unsigned long long allocation = 0;
+    virStoragePoolDefPtr def = virStoragePoolObjGetDef(pool);
+
+    if (!name)
+        return 0;
+
+    if (VIR_ALLOC(vol) < 0)
+        goto cleanup;
+
+    vol->type = VIR_STORAGE_VOL_BLOCK;
+    if (!(vol->name = g_strdup(name)))
+        goto cleanup;
+
+    if (virJSONValueObjectGetNumberUlong(item, "capacity", &capacity) == 0)
+        vol->target.capacity = capacity;
+
+    if (virJSONValueObjectGetNumberUlong(item, "allocation", &allocation) == 0)
+        vol->target.allocation = allocation;
+
+    if (path) {
+        if (!(vol->target.path = g_strdup(path)))
+            goto cleanup;
+    } else if (def->target.path) {
+        if (!(vol->target.path = g_strdup_printf("%s/%s", def->target.path, name)))
+            goto cleanup;
+    } else if (!(vol->target.path = g_strdup(name))) {
+        goto cleanup;
+    }
+
+    if (!(vol->key = g_strdup(vol->target.path)))
+        goto cleanup;
+
+    if (virStoragePoolObjAddVol(pool, vol) < 0)
+        goto cleanup;
+    vol = NULL;
+
+    return 0;
+
+ cleanup:
+    virStorageVolDefFree(vol);
+    return -1;
+}
+
+static char *
+virStorageBackendTrueNASFindPoolSources(const char *srcSpec ATTRIBUTE_UNUSED,
+                                        unsigned int flags)
+{
+    virJSONValuePtr params = NULL;
+    virJSONValuePtr result = NULL;
+    virJSONValuePtr pools = NULL;
+    virStoragePoolSourceList sourceList = {
+        .type = VIR_STORAGE_POOL_TRUENAS,
+        .nsources = 0,
+        .sources = NULL,
+    };
+    char *ret = NULL;
+    size_t i;
+    size_t j;
+
+    virCheckFlags(0, NULL);
+
+    if (!(params = virJSONValueNewObject()))
+        goto cleanup;
+
+    if (!(result = virStorageBackendTrueNASCall("pool.list", params)))
+        goto cleanup;
+    params = NULL;
+
+    if (!(pools = virJSONValueObjectGetArray(result, "pools"))) {
+        virReportError(VIR_ERR_INTERNAL_ERROR, "%s",
+                       _("TrueNAS provider pool.list result missing pools array"));
+        goto cleanup;
+    }
+
+    for (i = 0; i < virJSONValueArraySize(pools); i++) {
+        virJSONValuePtr item = virJSONValueArrayGet(pools, i);
+        const char *name = virJSONValueObjectGetString(item, "name");
+        virStoragePoolSourcePtr src;
+
+        if (!name)
+            continue;
+        if (!(src = virStoragePoolSourceListNewSource(&sourceList)))
+            goto cleanup;
+        if (!(src->name = g_strdup(name)))
+            goto cleanup;
+    }
+
+    ret = virStoragePoolSourceListFormat(&sourceList);
+
+ cleanup:
+    for (j = 0; j < sourceList.nsources; j++)
+        virStoragePoolSourceClear(&sourceList.sources[j]);
+    VIR_FREE(sourceList.sources);
+    virJSONValueFree(params);
+    virJSONValueFree(result);
+    return ret;
+}
+
+static int
+virStorageBackendTrueNASStartPool(virStoragePoolObjPtr pool)
+{
+    virStoragePoolDefPtr def = virStoragePoolObjGetDef(pool);
+
+    return virStorageBackendTrueNASValidate(def);
+}
+
+static int
+virStorageBackendTrueNASRefreshPool(virStoragePoolObjPtr pool)
+{
+    virStoragePoolDefPtr def = virStoragePoolObjGetDef(pool);
+    virJSONValuePtr params = NULL;
+    virJSONValuePtr result = NULL;
+    virJSONValuePtr poolinfo;
+    virJSONValuePtr volumes;
+    size_t i;
+    int ret = -1;
+
+    if (virStorageBackendTrueNASValidate(def) < 0)
+        return -1;
+
+    if (!(params = virJSONValueNewObject()))
+        goto cleanup;
+
+    if (virStorageBackendTrueNASAppendCommonParams(params, def) < 0)
+        goto cleanup;
+
+    if (!(result = virStorageBackendTrueNASCall("pool.refresh", params)))
+        goto cleanup;
+    params = NULL;
+
+    virStoragePoolObjClearVols(pool);
+
+    if ((poolinfo = virJSONValueObjectGetObject(result, "pool"))) {
+        unsigned long long capacity = 0;
+        unsigned long long allocation = 0;
+        unsigned long long available = 0;
+        if (virJSONValueObjectGetNumberUlong(poolinfo, "capacity", &capacity) == 0 &&
+            virJSONValueObjectGetNumberUlong(poolinfo, "allocation", &allocation) == 0 &&
+            virJSONValueObjectGetNumberUlong(poolinfo, "available", &available) == 0) {
+            def->capacity = capacity;
+            def->allocation = allocation;
+            def->available = available;
+        }
+    }
+
+    if (!(volumes = virJSONValueObjectGetArray(result, "volumes")))
+        goto cleanup;
+
+    for (i = 0; i < virJSONValueArraySize(volumes); i++) {
+        virJSONValuePtr item = virJSONValueArrayGet(volumes, i);
+        if (virStorageBackendTrueNASAddVolume(pool, item) < 0)
+            goto cleanup;
+    }
+
+    ret = 0;
+
+ cleanup:
+    virJSONValueFree(params);
+    virJSONValueFree(result);
+    return ret;
+}
+
+static int
+virStorageBackendTrueNASCreateVol(virStoragePoolObjPtr pool,
+                                  virStorageVolDefPtr vol)
+{
+    virStoragePoolDefPtr def = virStoragePoolObjGetDef(pool);
+    virJSONValuePtr params = NULL;
+    virJSONValuePtr result = NULL;
+    int ret = -1;
+
+    if (virStorageBackendTrueNASValidate(def) < 0)
+        return -1;
+
+    if (!(params = virJSONValueNewObject()))
+        goto cleanup;
+
+    if (virStorageBackendTrueNASAppendCommonParams(params, def) < 0 ||
+        virJSONValueObjectAppendString(params, "name", vol->name) < 0 ||
+        virJSONValueObjectAppendNumberUlong(params, "capacity", vol->target.capacity) < 0)
+        goto cleanup;
+
+    if (!(result = virStorageBackendTrueNASCall("vol.create", params)))
+        goto cleanup;
+    params = NULL;
+
+    VIR_FREE(vol->target.path);
+    if (!(vol->target.path = g_strdup(virJSONValueObjectGetString(result, "path"))))
+        goto cleanup;
+    VIR_FREE(vol->key);
+    if (!(vol->key = g_strdup(vol->target.path)))
+        goto cleanup;
+    vol->type = VIR_STORAGE_VOL_BLOCK;
+
+    ret = 0;
+
+ cleanup:
+    virJSONValueFree(params);
+    virJSONValueFree(result);
+    return ret;
+}
+
+static int
+virStorageBackendTrueNASBuildVolFrom(virStoragePoolObjPtr pool,
+                                     virStorageVolDefPtr origvol,
+                                     virStorageVolDefPtr newvol,
+                                     unsigned int flags)
+{
+    virStoragePoolDefPtr def = virStoragePoolObjGetDef(pool);
+    virJSONValuePtr params = NULL;
+    virJSONValuePtr result = NULL;
+    unsigned long long resultCapacity = 0;
+    unsigned long long resultAllocation = 0;
+    int ret = -1;
+
+    virCheckFlags(0, -1);
+
+    if (virStorageBackendTrueNASValidate(def) < 0)
+        return -1;
+
+    if (!(params = virJSONValueNewObject()))
+        goto cleanup;
+
+    if (virStorageBackendTrueNASAppendCommonParams(params, def) < 0 ||
+        virJSONValueObjectAppendString(params, "source", origvol->name) < 0 ||
+        virJSONValueObjectAppendString(params, "target", newvol->name) < 0 ||
+        virJSONValueObjectAppendBoolean(params, "replace_existing", true) < 0)
+        goto cleanup;
+
+    if (!(result = virStorageBackendTrueNASCall("vol.clone", params)))
+        goto cleanup;
+    params = NULL;
+
+    VIR_FREE(newvol->target.path);
+    if (!(newvol->target.path = g_strdup(virJSONValueObjectGetString(result, "path"))))
+        goto cleanup;
+    VIR_FREE(newvol->key);
+    if (!(newvol->key = g_strdup(newvol->target.path)))
+        goto cleanup;
+
+    if (virJSONValueObjectGetNumberUlong(result, "capacity", &resultCapacity) == 0)
+        newvol->target.capacity = resultCapacity;
+    if (virJSONValueObjectGetNumberUlong(result, "allocation", &resultAllocation) == 0)
+        newvol->target.allocation = resultAllocation;
+    newvol->type = VIR_STORAGE_VOL_BLOCK;
+
+    ret = 0;
+
+ cleanup:
+    virJSONValueFree(params);
+    virJSONValueFree(result);
+    return ret;
+}
+
+static int
+virStorageBackendTrueNASResizeVol(virStoragePoolObjPtr pool,
+                                  virStorageVolDefPtr vol,
+                                  unsigned long long capacity,
+                                  unsigned int flags)
+{
+    virStoragePoolDefPtr def = virStoragePoolObjGetDef(pool);
+    virJSONValuePtr params = NULL;
+    virJSONValuePtr result = NULL;
+    unsigned long long resultCapacity = 0;
+    unsigned long long resultAllocation = 0;
+    int ret = -1;
+
+    if (flags & VIR_STORAGE_VOL_RESIZE_ALLOCATE) {
+        virReportError(VIR_ERR_CONFIG_UNSUPPORTED, "%s",
+                       _("TrueNAS volumes do not support resize allocation requests"));
+        return -1;
+    }
+
+    if (virStorageBackendTrueNASValidate(def) < 0)
+        return -1;
+
+    if (!(params = virJSONValueNewObject()))
+        goto cleanup;
+
+    if (virStorageBackendTrueNASAppendCommonParams(params, def) < 0 ||
+        virJSONValueObjectAppendString(params, "name", vol->name) < 0 ||
+        virJSONValueObjectAppendNumberUlong(params, "capacity", capacity) < 0)
+        goto cleanup;
+
+    if (!(result = virStorageBackendTrueNASCall("vol.resize", params)))
+        goto cleanup;
+    params = NULL;
+
+    if (virJSONValueObjectGetNumberUlong(result, "capacity", &resultCapacity) == 0)
+        vol->target.capacity = resultCapacity;
+    else
+        vol->target.capacity = capacity;
+    if (virJSONValueObjectGetNumberUlong(result, "allocation", &resultAllocation) == 0)
+        vol->target.allocation = resultAllocation;
+
+    ret = 0;
+
+ cleanup:
+    virJSONValueFree(params);
+    virJSONValueFree(result);
+    return ret;
+}
+
+static int
+virStorageBackendTrueNASDeleteVol(virStoragePoolObjPtr pool,
+                                  virStorageVolDefPtr vol,
+                                  unsigned int flags)
+{
+    virStoragePoolDefPtr def = virStoragePoolObjGetDef(pool);
+    virJSONValuePtr params = NULL;
+    virJSONValuePtr result = NULL;
+    bool deleteSnapshots = flags & VIR_STORAGE_VOL_DELETE_WITH_SNAPSHOTS;
+    int ret = -1;
+
+    virCheckFlags(VIR_STORAGE_VOL_DELETE_WITH_SNAPSHOTS, -1);
+
+    if (!(params = virJSONValueNewObject()))
+        goto cleanup;
+
+    if (virStorageBackendTrueNASAppendCommonParams(params, def) < 0 ||
+        virJSONValueObjectAppendString(params, "name", vol->name) < 0 ||
+        virJSONValueObjectAppendBoolean(params, "delete_snapshots", deleteSnapshots) < 0)
+        goto cleanup;
+
+    if (!(result = virStorageBackendTrueNASCall("vol.delete", params)))
+        goto cleanup;
+    params = NULL;
+
+    ret = 0;
+
+ cleanup:
+    virJSONValueFree(params);
+    virJSONValueFree(result);
+    return ret;
+}
+
+virStorageBackend virStorageBackendTrueNAS = {
+    .type = VIR_STORAGE_POOL_TRUENAS,
+
+    .findPoolSources = virStorageBackendTrueNASFindPoolSources,
+    .startPool = virStorageBackendTrueNASStartPool,
+    .refreshPool = virStorageBackendTrueNASRefreshPool,
+    .createVol = virStorageBackendTrueNASCreateVol,
+    .buildVolFrom = virStorageBackendTrueNASBuildVolFrom,
+    .deleteVol = virStorageBackendTrueNASDeleteVol,
+    .resizeVol = virStorageBackendTrueNASResizeVol,
+};
+
+int
+virStorageBackendTrueNASRegister(void)
+{
+    return virStorageBackendRegister(&virStorageBackendTrueNAS);
+}
