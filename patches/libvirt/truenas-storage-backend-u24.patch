diff --git a/src/storage/storage_backend_truenas.c b/src/storage/storage_backend_truenas.c
new file mode 100644
index 0000000..4594727
--- /dev/null
+++ b/src/storage/storage_backend_truenas.c
@@ -0,0 +1,510 @@
+/*
+ * storage_backend_truenas.c: storage backend for TrueNAS provider daemon
+ */
+
+#include <config.h>
+
+#include <errno.h>
+#include <sys/socket.h>
+#include <sys/un.h>
+#include <unistd.h>
+
+#include "storage_conf.h"
+#include "storage_backend_truenas.h"
+#include "storage_util.h"
+#include "viralloc.h"
+#include "virerror.h"
+#include "virfile.h"
+#include "virjson.h"
+#include "virlog.h"
+#include "virstring.h"
+
+#define VIR_FROM_THIS VIR_FROM_STORAGE
+
+VIR_LOG_INIT("storage.storage_backend_truenas");
+
+#define TRUENAS_PROVIDER_SOCKET "/run/truenas-libvirt/provider.sock"
+
+static const char *
+virStorageBackendTrueNASTransport(virStoragePoolDef *def)
+{
+    if (def->source.protocolType)
+        return def->source.protocolType;
+
+    return def->source.product;
+}
+
+static int
+virStorageBackendTrueNASValidate(virStoragePoolDef *def)
+{
+    const char *transport = virStorageBackendTrueNASTransport(def);
+
+    if (!def->source.name) {
+        virReportError(VIR_ERR_CONFIG_UNSUPPORTED, "%s",
+                       _("TrueNAS pool requires source name"));
+        return -1;
+    }
+
+    if (!transport ||
+        (STRNEQ(transport, "iscsi") && STRNEQ(transport, "nvmeof"))) {
+        virReportError(VIR_ERR_CONFIG_UNSUPPORTED, "%s",
+                       _("TrueNAS pool protocol must be 'iscsi' or 'nvmeof'"));
+        return -1;
+    }
+
+    return 0;
+}
+
+static int
+virStorageBackendTrueNASConnect(void)
+{
+    struct sockaddr_un addr = { 0 };
+    int fd;
+
+    if ((fd = socket(AF_UNIX, SOCK_STREAM, 0)) < 0) {
+        virReportSystemError(errno, "%s", _("failed to create TrueNAS provider socket"));
+        return -1;
+    }
+
+    addr.sun_family = AF_UNIX;
+    if (virStrcpyStatic(addr.sun_path, TRUENAS_PROVIDER_SOCKET) < 0) {
+        virReportError(VIR_ERR_INTERNAL_ERROR, "%s", _("TrueNAS provider socket path is too long"));
+        VIR_FORCE_CLOSE(fd);
+        return -1;
+    }
+
+    if (connect(fd, (struct sockaddr *) &addr, sizeof(addr)) < 0) {
+        virReportSystemError(errno,
+                             _("TrueNAS provider daemon is not available at %1$s; install/configure the truenas-libvirt-provider package and start truenas-libvirt-provider.service"),
+                             TRUENAS_PROVIDER_SOCKET);
+        VIR_FORCE_CLOSE(fd);
+        return -1;
+    }
+
+    return fd;
+}
+
+static virJSONValue *
+virStorageBackendTrueNASCall(const char *method,
+                             virJSONValue **params)
+{
+    VIR_AUTOCLOSE fd = -1;
+    g_autofree char *requeststr = NULL;
+    g_autofree char *responsestr = NULL;
+    g_autoptr(virJSONValue) request = virJSONValueNewObject();
+    g_autoptr(virJSONValue) response = NULL;
+    virJSONValue *result = NULL;
+    virJSONValue *error = NULL;
+    g_autoptr(GString) responsebuf = g_string_new(NULL);
+    g_autofree char *buf = g_new0(char, 4096);
+    ssize_t got;
+
+    if (!request)
+        return NULL;
+
+    if (virJSONValueObjectAppendString(request, "jsonrpc", "2.0") < 0 ||
+        virJSONValueObjectAppendNumberInt(request, "id", 1) < 0 ||
+        virJSONValueObjectAppendString(request, "method", method) < 0 ||
+        virJSONValueObjectAppend(request, "params", params) < 0)
+        return NULL;
+
+    if (!(requeststr = virJSONValueToString(request, false)))
+        return NULL;
+
+    if ((fd = virStorageBackendTrueNASConnect()) < 0)
+        return NULL;
+
+    if (safewrite(fd, requeststr, strlen(requeststr)) < 0 ||
+        safewrite(fd, "\n", 1) < 0) {
+        virReportSystemError(errno, "%s", _("failed to write TrueNAS provider request"));
+        return NULL;
+    }
+
+    while (true) {
+        got = read(fd, buf, 4096);
+        if (got < 0 && errno == EINTR)
+            continue;
+        if (got <= 0)
+            break;
+
+        if (responsebuf->len + got > 1024 * 1024) {
+            virReportError(VIR_ERR_INTERNAL_ERROR, "%s",
+                           _("TrueNAS provider response is too large"));
+            return NULL;
+        }
+
+        g_string_append_len(responsebuf, buf, got);
+        if (memchr(buf, '\n', got))
+            break;
+    }
+
+    if (got < 0) {
+        virReportSystemError(errno, "%s", _("failed to read TrueNAS provider response"));
+        return NULL;
+    }
+
+    if (!responsebuf->len) {
+        virReportError(VIR_ERR_INTERNAL_ERROR, "%s",
+                       _("empty response from TrueNAS provider"));
+        return NULL;
+    }
+
+    responsestr = g_string_free(g_steal_pointer(&responsebuf), false);
+
+    if (!(response = virJSONValueFromString(responsestr))) {
+        virReportError(VIR_ERR_INTERNAL_ERROR, "%s", _("invalid JSON from TrueNAS provider"));
+        return NULL;
+    }
+
+    if ((error = virJSONValueObjectGetObject(response, "error"))) {
+        const char *message = virJSONValueObjectGetString(error, "message");
+        virReportError(VIR_ERR_INTERNAL_ERROR,
+                       _("TrueNAS provider error: %1$s"), NULLSTR(message));
+        return NULL;
+    }
+
+    if (virJSONValueObjectRemoveKey(response, "result", &result) <= 0) {
+        virReportError(VIR_ERR_INTERNAL_ERROR, "%s", _("missing result from TrueNAS provider"));
+        return NULL;
+    }
+
+    return result;
+}
+
+static int
+virStorageBackendTrueNASAppendCommonParams(virJSONValue *params,
+                                           virStoragePoolDef *def)
+{
+    const char *transport = virStorageBackendTrueNASTransport(def);
+
+    return virJSONValueObjectAppendString(params, "pool", def->source.name) < 0 ||
+           virJSONValueObjectAppendString(params, "transport", transport) < 0 ? -1 : 0;
+}
+
+static int
+virStorageBackendTrueNASAddVolume(virStoragePoolObj *pool,
+                                  virJSONValue *item)
+{
+    virStoragePoolDef *def = virStoragePoolObjGetDef(pool);
+    g_autoptr(virStorageVolDef) vol = g_new0(virStorageVolDef, 1);
+    const char *name = virJSONValueObjectGetString(item, "name");
+    const char *path = virJSONValueObjectGetString(item, "path");
+    unsigned long long capacity = 0;
+    unsigned long long allocation = 0;
+
+    if (!name)
+        return 0;
+
+    vol->name = g_strdup(name);
+    vol->type = VIR_STORAGE_VOL_BLOCK;
+    vol->target.format = VIR_STORAGE_FILE_RAW;
+
+    if (virJSONValueObjectGetNumberUlong(item, "capacity", &capacity) == 0)
+        vol->target.capacity = capacity;
+    if (virJSONValueObjectGetNumberUlong(item, "allocation", &allocation) == 0)
+        vol->target.allocation = allocation;
+
+    if (path)
+        vol->target.path = g_strdup(path);
+    else if (def->target.path)
+        vol->target.path = g_strdup_printf("%s/%s", def->target.path, name);
+    else
+        vol->target.path = g_strdup(name);
+
+    vol->key = g_strdup(vol->target.path);
+
+    if (virStoragePoolObjAddVol(pool, vol) < 0)
+        return -1;
+
+    g_steal_pointer(&vol);
+    return 0;
+}
+
+static char *
+virStorageBackendTrueNASFindPoolSources(const char *srcSpec G_GNUC_UNUSED,
+                                        unsigned int flags)
+{
+    g_autoptr(virJSONValue) params = virJSONValueNewObject();
+    g_autoptr(virJSONValue) result = NULL;
+    virJSONValue *pools;
+    g_autofree virStoragePoolSourceList *sourceList = g_new0(virStoragePoolSourceList, 1);
+    char *retval = NULL;
+    size_t i;
+    size_t nvalid = 0;
+
+    virCheckFlags(0, NULL);
+
+    if (!params)
+        return NULL;
+
+    if (!(result = virStorageBackendTrueNASCall("pool.list", &params)))
+        return NULL;
+
+    if (!(pools = virJSONValueObjectGetArray(result, "pools"))) {
+        virReportError(VIR_ERR_INTERNAL_ERROR, "%s",
+                       _("missing pools array from TrueNAS provider"));
+        return NULL;
+    }
+
+    for (i = 0; i < virJSONValueArraySize(pools); i++) {
+        virJSONValue *item = virJSONValueArrayGet(pools, i);
+        const char *name = virJSONValueObjectGetString(item, "name");
+
+        if (name && *name)
+            nvalid++;
+    }
+
+    sourceList->type = VIR_STORAGE_POOL_TRUENAS;
+    sourceList->nsources = nvalid;
+    sourceList->sources = g_new0(virStoragePoolSource, nvalid);
+
+    nvalid = 0;
+    for (i = 0; i < virJSONValueArraySize(pools); i++) {
+        virJSONValue *item = virJSONValueArrayGet(pools, i);
+        const char *name = virJSONValueObjectGetString(item, "name");
+
+        if (name && *name)
+            sourceList->sources[nvalid++].name = g_strdup(name);
+    }
+
+    retval = virStoragePoolSourceListFormat(sourceList);
+
+    for (i = 0; i < sourceList->nsources; i++)
+        virStoragePoolSourceClear(&sourceList->sources[i]);
+    VIR_FREE(sourceList->sources);
+
+    return retval;
+}
+
+static int
+virStorageBackendTrueNASStartPool(virStoragePoolObj *pool)
+{
+    virStoragePoolDef *def = virStoragePoolObjGetDef(pool);
+    return virStorageBackendTrueNASValidate(def);
+}
+
+static int
+virStorageBackendTrueNASRefreshPool(virStoragePoolObj *pool)
+{
+    virStoragePoolDef *def = virStoragePoolObjGetDef(pool);
+    g_autoptr(virJSONValue) params = virJSONValueNewObject();
+    g_autoptr(virJSONValue) result = NULL;
+    virJSONValue *poolinfo;
+    virJSONValue *volumes;
+    bool havePoolSpace = false;
+    size_t i;
+
+    if (virStorageBackendTrueNASValidate(def) < 0)
+        return -1;
+
+    if (virStorageBackendTrueNASAppendCommonParams(params, def) < 0)
+        return -1;
+
+    if (!(result = virStorageBackendTrueNASCall("pool.refresh", &params)))
+        return -1;
+
+    virStoragePoolObjClearVols(pool);
+    def->allocation = def->capacity = def->available = 0;
+
+    if ((poolinfo = virJSONValueObjectGetObject(result, "pool"))) {
+        unsigned long long capacity = 0;
+        unsigned long long allocation = 0;
+        unsigned long long available = 0;
+
+        if (virJSONValueObjectGetNumberUlong(poolinfo, "capacity", &capacity) == 0 &&
+            virJSONValueObjectGetNumberUlong(poolinfo, "allocation", &allocation) == 0 &&
+            virJSONValueObjectGetNumberUlong(poolinfo, "available", &available) == 0) {
+            def->capacity = capacity;
+            def->allocation = allocation;
+            def->available = available;
+            havePoolSpace = true;
+        }
+    }
+
+    if (!(volumes = virJSONValueObjectGetArray(result, "volumes")))
+        return 0;
+
+    for (i = 0; i < virJSONValueArraySize(volumes); i++) {
+        virJSONValue *item = virJSONValueArrayGet(volumes, i);
+        unsigned long long capacity = 0;
+        unsigned long long allocation = 0;
+
+        if (virStorageBackendTrueNASAddVolume(pool, item) < 0)
+            return -1;
+        if (!havePoolSpace) {
+            if (virJSONValueObjectGetNumberUlong(item, "capacity", &capacity) == 0)
+                def->capacity += capacity;
+            if (virJSONValueObjectGetNumberUlong(item, "allocation", &allocation) == 0)
+                def->allocation += allocation;
+        }
+    }
+
+    return 0;
+}
+
+static int
+virStorageBackendTrueNASCreateVol(virStoragePoolObj *pool,
+                                  virStorageVolDef *vol)
+{
+    virStoragePoolDef *def = virStoragePoolObjGetDef(pool);
+    g_autoptr(virJSONValue) params = virJSONValueNewObject();
+    g_autoptr(virJSONValue) result = NULL;
+
+    if (virStorageBackendTrueNASValidate(def) < 0)
+        return -1;
+
+    if (virStorageBackendTrueNASAppendCommonParams(params, def) < 0 ||
+        virJSONValueObjectAppendString(params, "name", vol->name) < 0 ||
+        virJSONValueObjectAppendNumberUlong(params, "capacity", vol->target.capacity) < 0)
+        return -1;
+
+    if (!(result = virStorageBackendTrueNASCall("vol.create", &params)))
+        return -1;
+
+    VIR_FREE(vol->target.path);
+    vol->target.path = g_strdup(virJSONValueObjectGetString(result, "path"));
+    VIR_FREE(vol->key);
+    vol->key = g_strdup(vol->target.path);
+    vol->type = VIR_STORAGE_VOL_BLOCK;
+    vol->target.format = VIR_STORAGE_FILE_RAW;
+
+    return 0;
+}
+
+static int
+virStorageBackendTrueNASBuildVolFrom(virStoragePoolObj *pool,
+                                     virStorageVolDef *newvol,
+                                     virStorageVolDef *origvol,
+                                     unsigned int flags)
+{
+    virStoragePoolDef *def = virStoragePoolObjGetDef(pool);
+    g_autoptr(virJSONValue) params = virJSONValueNewObject();
+    g_autoptr(virJSONValue) result = NULL;
+    const char *path = NULL;
+    unsigned long long resultCapacity = 0;
+    unsigned long long resultAllocation = 0;
+
+    virCheckFlags(0, -1);
+
+    if (virStorageBackendTrueNASValidate(def) < 0)
+        return -1;
+
+    if (virStorageBackendTrueNASAppendCommonParams(params, def) < 0 ||
+        virJSONValueObjectAppendString(params, "source", origvol->name) < 0 ||
+        virJSONValueObjectAppendString(params, "target", newvol->name) < 0 ||
+        virJSONValueObjectAppendBoolean(params, "replace_existing", true) < 0)
+        return -1;
+
+    if (!(result = virStorageBackendTrueNASCall("vol.clone", &params)))
+        return -1;
+
+    if ((path = virJSONValueObjectGetString(result, "path"))) {
+        VIR_FREE(newvol->target.path);
+        newvol->target.path = g_strdup(path);
+        VIR_FREE(newvol->key);
+        newvol->key = g_strdup(newvol->target.path);
+    }
+
+    if (virJSONValueObjectGetNumberUlong(result, "capacity", &resultCapacity) == 0)
+        newvol->target.capacity = resultCapacity;
+    if (virJSONValueObjectGetNumberUlong(result, "allocation", &resultAllocation) == 0)
+        newvol->target.allocation = resultAllocation;
+
+    newvol->type = VIR_STORAGE_VOL_BLOCK;
+    newvol->target.format = VIR_STORAGE_FILE_RAW;
+    return 0;
+}
+
+static int
+virStorageBackendTrueNASResizeVol(virStoragePoolObj *pool,
+                                  virStorageVolDef *vol,
+                                  unsigned long long capacity,
+                                  unsigned int flags)
+{
+    virStoragePoolDef *def = virStoragePoolObjGetDef(pool);
+    g_autoptr(virJSONValue) params = virJSONValueNewObject();
+    g_autoptr(virJSONValue) result = NULL;
+    unsigned long long resultCapacity = 0;
+    unsigned long long resultAllocation = 0;
+
+    if (flags & VIR_STORAGE_VOL_RESIZE_ALLOCATE) {
+        virReportError(VIR_ERR_CONFIG_UNSUPPORTED, "%s",
+                       _("TrueNAS volumes do not support resize allocation"));
+        return -1;
+    }
+
+    if (flags & VIR_STORAGE_VOL_RESIZE_SHRINK) {
+        virReportError(VIR_ERR_CONFIG_UNSUPPORTED, "%s",
+                       _("TrueNAS volumes do not support shrinking"));
+        return -1;
+    }
+
+    virCheckFlags(0, -1);
+
+    if (capacity < vol->target.capacity) {
+        virReportError(VIR_ERR_CONFIG_UNSUPPORTED, "%s",
+                       _("TrueNAS volume resize is grow-only"));
+        return -1;
+    }
+
+    if (virStorageBackendTrueNASValidate(def) < 0)
+        return -1;
+
+    if (virStorageBackendTrueNASAppendCommonParams(params, def) < 0 ||
+        virJSONValueObjectAppendString(params, "name", vol->name) < 0 ||
+        virJSONValueObjectAppendNumberUlong(params, "capacity", capacity) < 0)
+        return -1;
+
+    if (!(result = virStorageBackendTrueNASCall("vol.resize", &params)))
+        return -1;
+
+    if (virJSONValueObjectGetNumberUlong(result, "capacity", &resultCapacity) == 0)
+        vol->target.capacity = resultCapacity;
+    else
+        vol->target.capacity = capacity;
+
+    if (virJSONValueObjectGetNumberUlong(result, "allocation", &resultAllocation) == 0)
+        vol->target.allocation = resultAllocation;
+
+    return 0;
+}
+
+static int
+virStorageBackendTrueNASDeleteVol(virStoragePoolObj *pool,
+                                  virStorageVolDef *vol,
+                                  unsigned int flags)
+{
+    virStoragePoolDef *def = virStoragePoolObjGetDef(pool);
+    g_autoptr(virJSONValue) params = virJSONValueNewObject();
+    g_autoptr(virJSONValue) result = NULL;
+    bool deleteSnapshots = !!(flags & VIR_STORAGE_VOL_DELETE_WITH_SNAPSHOTS);
+
+    virCheckFlags(VIR_STORAGE_VOL_DELETE_WITH_SNAPSHOTS, -1);
+
+    if (virStorageBackendTrueNASAppendCommonParams(params, def) < 0 ||
+        virJSONValueObjectAppendString(params, "name", vol->name) < 0 ||
+        virJSONValueObjectAppendBoolean(params, "delete_snapshots", deleteSnapshots) < 0)
+        return -1;
+
+    if (!(result = virStorageBackendTrueNASCall("vol.delete", &params)))
+        return -1;
+
+    return 0;
+}
+
+virStorageBackend virStorageBackendTrueNAS = {
+    .type = VIR_STORAGE_POOL_TRUENAS,
+    .findPoolSources = virStorageBackendTrueNASFindPoolSources,
+    .startPool = virStorageBackendTrueNASStartPool,
+    .refreshPool = virStorageBackendTrueNASRefreshPool,
+    .createVol = virStorageBackendTrueNASCreateVol,
+    .buildVolFrom = virStorageBackendTrueNASBuildVolFrom,
+    .deleteVol = virStorageBackendTrueNASDeleteVol,
+    .resizeVol = virStorageBackendTrueNASResizeVol,
+};
+
+int
+virStorageBackendTrueNASRegister(void)
+{
+    return virStorageBackendRegister(&virStorageBackendTrueNAS);
+}
