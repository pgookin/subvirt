{
  "project": {
    "name": "subvirt",
    "repo_url": "https://github.com/pgookin/subvirt.git",
    "branch": "main",
    "workdir": "/srv/subvirt/build",
    "artifact_dir": "/srv/subvirt/artifacts",
    "source_mode": "git"
  },
  "hosts": {
    "build": "build-host",
    "ubuntu_test": "ubuntu-test-host",
    "alma_test": "alma-test-host",
    "migration_source": "ubuntu-test-host",
    "migration_target": "ubuntu-migration-peer-host",
    "repo": "internal-repo-host",
    "public_repo": "subvirt-publish@repo.subvirt.net"
  },
  "repos": {
    "aptly_repo_prefix": "subvirt-ubuntu-noble",
    "apt_distribution": "noble",
    "apt_component": "main",
    "yum_distro_path": "almalinux/10",
    "web_root": "/srv/repo/www",
    "apt_distributions": [
      "bionic",
      "focal",
      "jammy",
      "noble",
      "resolute"
    ],
    "yum_distro_paths": [
      "almalinux/9",
      "almalinux/10"
    ]
  },
  "public_repo": {
    "host": "subvirt-publish@repo.subvirt.net",
    "incoming_root": "/srv/subvirt/incoming",
    "web_root": "/srv/repo/www",
    "apt_distribution": "noble",
    "yum_distro_path": "almalinux/10",
    "base_url": "https://repo.subvirt.net",
    "gpg_name": "Subvirt Repository <repo@subvirt.net>",
    "publish_script": "/usr/local/libexec/subvirt/publish-repo.py",
    "apt_distributions": [
      "bionic",
      "focal",
      "jammy",
      "noble",
      "resolute"
    ],
    "yum_distro_paths": [
      "almalinux/9",
      "almalinux/10"
    ]
  },
  "tests": {
    "pool": "tank",
    "iscsi_pool": "truenas-tank-iscsi",
    "nvmeof_pool": "truenas-tank-nvmeof",
    "iscsi_pool_xml": "examples/storage-pool-tank-iscsi.xml",
    "nvmeof_pool_xml": "examples/storage-pool-tank-nvmeof.xml",
    "migration_domain": "subvirt-migration-smoke",
    "migration_image_url": "https://download.cirros-cloud.net/0.6.2/cirros-0.6.2-x86_64-disk.img",
    "migration_image_sha256": "",
    "migration_volume_size": "512M",
    "migration_machine": "auto",
    "run_migration": false
  },
  "upstream": {
    "mirrors": {
      "ubuntu": "http://archive.ubuntu.com/ubuntu",
      "alma": "https://repo.almalinux.org/almalinux"
    },
    "ubuntu_suite": "noble",
    "ubuntu_pockets": [
      "updates",
      "security"
    ],
    "ubuntu_component": "main",
    "ubuntu_arch": "amd64",
    "alma_appstream_path": "10/AppStream/x86_64_v2/os",
    "ubuntu_targets": [
      {
        "id": "ubuntu-18.04",
        "version": "18.04",
        "suite": "bionic",
        "support_tier": "esm",
        "source_dir": "u18",
        "build_dir_prefix": "libvirt-u18",
        "patch": "truenas-storage-backend-u24.patch",
        "containerfile": "containers/ubuntu-18.04-build/Containerfile",
        "image": "localhost/subvirt-ubuntu-18.04-build:latest"
      },
      {
        "id": "ubuntu-20.04",
        "version": "20.04",
        "suite": "focal",
        "support_tier": "esm",
        "source_dir": "u20",
        "build_dir_prefix": "libvirt-u20",
        "patch": "truenas-storage-backend-u24.patch",
        "containerfile": "containers/ubuntu-20.04-build/Containerfile",
        "image": "localhost/subvirt-ubuntu-20.04-build:latest"
      },
      {
        "id": "ubuntu-22.04",
        "version": "22.04",
        "suite": "jammy",
        "support_tier": "standard",
        "source_dir": "u22",
        "build_dir_prefix": "libvirt-u22",
        "patch": "truenas-storage-backend-u24.patch",
        "containerfile": "containers/ubuntu-22.04-build/Containerfile",
        "image": "localhost/subvirt-ubuntu-22.04-build:latest"
      },
      {
        "id": "ubuntu-24.04",
        "version": "24.04",
        "suite": "noble",
        "support_tier": "standard",
        "source_dir": "u24",
        "build_dir_prefix": "libvirt-u24",
        "patch": "truenas-storage-backend-u24.patch",
        "containerfile": "containers/ubuntu-24.04-build/Containerfile",
        "image": "localhost/subvirt-ubuntu-24.04-build:latest"
      },
      {
        "id": "ubuntu-26.04",
        "version": "26.04",
        "suite": "resolute",
        "support_tier": "standard",
        "source_dir": "u26",
        "build_dir_prefix": "libvirt-u26",
        "patch": "truenas-storage-backend-u24.patch",
        "containerfile": "containers/ubuntu-26.04-build/Containerfile",
        "image": "localhost/subvirt-ubuntu-26.04-build:latest"
      }
    ],
    "alma_targets": [
      {
        "id": "almalinux-9",
        "version": "9",
        "source_dir": "al9",
        "repo_path": "9/AppStream/x86_64/os",
        "yum_distro_path": "almalinux/9",
        "patch": "truenas-storage-backend-al10.patch",
        "containerfile": "containers/almalinux-9-build/Containerfile",
        "image": "localhost/subvirt-almalinux-9-build:latest",
        "mock_config": "almalinux-9-x86_64"
      },
      {
        "id": "almalinux-10",
        "version": "10",
        "source_dir": "al10",
        "repo_path": "10/AppStream/x86_64_v2/os",
        "yum_distro_path": "almalinux/10",
        "patch": "truenas-storage-backend-al10.patch",
        "containerfile": "containers/almalinux-10-build/Containerfile",
        "image": "localhost/subvirt-almalinux-10-build:latest",
        "mock_config": "almalinux-10-x86_64"
      }
    ]
  },
  "lab": {
    "enabled": false,
    "full": false,
    "host": "build-host",
    "config": "/srv/subvirt/release/lab.json"
  }
}
